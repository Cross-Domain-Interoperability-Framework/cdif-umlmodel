                            xmi:uuid="https://example.org/cdifcodelist#Concept-altLabel-lowerValue"
                            xmi:type="uml:LiteralInteger">
                  <value>0</value>
               </lowerValue>
               <upperValue xmi:id="skos.Concept-altLabel-upperValue"
                            xmi:uuid="https://example.org/cdifcodelist#Concept-altLabel-upperValue"
                            xmi:type="uml:LiteralUnlimitedNatural">
                  <value>*</value>
               </upperValue>
            </ownedAttribute>
            <ownedAttribute xmi:id="skos.Concept-definition"
