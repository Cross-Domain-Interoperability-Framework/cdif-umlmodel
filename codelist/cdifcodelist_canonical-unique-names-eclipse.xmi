                             xmi:uuid="https://example.org/cdifcodelist#ConceptScheme-ownedAttribute-1"
                             xmi:type="uml:Property">
               <type xmi:idref="skos.Concept"/>
               <association xmi:idref="skos.ConceptScheme_hasTopConcept_Concept"/>
            </ownedAttribute>
         </packagedElement>
