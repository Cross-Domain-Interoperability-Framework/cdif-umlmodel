					</attribute>
					<attribute xmi:idref="EAID_A48E487C_7891_4EC4_B178_C359588F017E" name="prefLabel" scope="Public">
						<initial/>
						<documentation value="The prefLabel property makes it possible to assign a preferred lexical label to a resource. The label provides the strongest clues as to the meaning of a SKOS concept. A lexical label is a string of UNICODE characters, such as &quot;romantic love&quot;, in a given natural language, such as English. A resource has no more than one value of prefLabel per language property.&#xA;https://www.w3.org/TR/skos-reference/#prefLabel"/>
						<model ea_localid="1" ea_guid="{A48E487C-7891-4EC4-B178-C359588F017E}"/>
