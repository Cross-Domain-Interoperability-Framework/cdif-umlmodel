					<attribute xmi:idref="EAID_A336D238_68F9_0E65_87F1_D98233D139DA" name="definition" scope="Public">
						<initial/>
						<documentation value="Definition supplies a complete explanation of the intended meaning of a concept.&#xA;https://www.w3.org/TR/skos-reference/#definition"/>
						<model ea_localid="4" ea_guid="{A336D238-68F9-0E65-87F1-D98233D139DA}"/>
						<properties type="LanguageString" precision="0" collection="false" length="0" static="0" duplicates="0" changeability="changeable"/>
