					<attribute xmi:idref="EAID_88454ADA_F8FA_5045_8185_42D9885699BE" name="identifier" scope="Public">
						<initial/>
						<documentation value="Globally unique, resolvable URI."/>
						<model ea_localid="5" ea_guid="{88454ADA-F8FA-5045-8185-42D9885699BE}"/>
