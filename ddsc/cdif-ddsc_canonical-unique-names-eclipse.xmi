                               xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#DataStore-ownedAttribute-2-upperValue"
                               xmi:type="uml:LiteralUnlimitedNatural">
                     <value>*</value>
                  </upperValue>
                  <association xmi:idref="ddsc.DataStore_has_LogicalRecord"/>
               </ownedAttribute>
            </packagedElement>
