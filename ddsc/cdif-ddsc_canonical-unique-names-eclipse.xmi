                  <association xmi:idref="ddsc.LogicalRecord_isDefinedBy_Population"/>
               </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:id="ddsc.WideDataStructure"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#WideDataStructure"
                              xmi:type="uml:Class">
               <ownedComment xmi:id="ddsc.WideDataStructure-ownedComment"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#WideDataStructure-ownedComment"
                              xmi:type="uml:Comment">
                  <body>Definition
==========
Structure of a wide dataset (organized collection of wide data). It is described by identifier, measure and attribute components.

Examples
==========
The structure described by [Unit id, Income, Province] where Unit id identifies a statistical unit and Income and Province are two instance variables capturing characteristics.</body>
                  <annotatedElement xmi:idref="ddsc.WideDataStructure"/>
               </ownedComment>
               <name>WideDataStructure</name>
               <ownedAttribute xmi:id="ddsc.WideDataStructure-ownedAttribute-1"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#WideDataStructure-ownedAttribute-1"
