                  </ownedComment>
                  <name>name</name>
                  <type xmi:idref="ddsc.ObjectName"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.RepresentedVariable-definition"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#RepresentedVariable-definition"
                                xmi:type="uml:Property">
                  <ownedComment xmi:id="ddsc.RepresentedVariable-definition-ownedComment"
