                                xmi:type="uml:Property">
                  <type xmi:idref="ddsc.IdentifierComponent"/>
                  <upperValue xmi:id="ddsc.LongDataStructure-ownedAttribute-1-upperValue"
                               xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#LongDataStructure-ownedAttribute-1-upperValue"
                               xmi:type="uml:LiteralUnlimitedNatural">
                     <value>*</value>
                  </upperValue>
                  <association xmi:idref="ddsc.LongDataStructure_has_IdentifierComponent"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.LongDataStructure-ownedAttribute-2"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#LongDataStructure-ownedAttribute-2"
                                xmi:type="uml:Property">
                  <type xmi:idref="ddsc.AttributeComponent"/>
                  <upperValue xmi:id="ddsc.LongDataStructure-ownedAttribute-2-upperValue"
                               xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#LongDataStructure-ownedAttribute-2-upperValue"
                               xmi:type="uml:LiteralUnlimitedNatural">
                     <value>*</value>
                  </upperValue>
                  <association xmi:idref="ddsc.LongDataStructure_has_AttributeComponent"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.LongDataStructure-ownedAttribute-3"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#LongDataStructure-ownedAttribute-3"
                                xmi:type="uml:Property">
                  <type xmi:idref="ddsc.VariableDescriptorComponent"/>
                  <upperValue xmi:id="ddsc.LongDataStructure-ownedAttribute-3-upperValue"
                               xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#LongDataStructure-ownedAttribute-3-upperValue"
                               xmi:type="uml:LiteralUnlimitedNatural">
                     <value>*</value>
                  </upperValue>
                  <association xmi:idref="ddsc.LongDataStructure_has_VariableDescriptorComponent"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.LongDataStructure-ownedAttribute-4"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#LongDataStructure-ownedAttribute-4"
                                xmi:type="uml:Property">
                  <type xmi:idref="ddsc.VariableValueComponent"/>
                  <upperValue xmi:id="ddsc.LongDataStructure-ownedAttribute-4-upperValue"
                               xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#LongDataStructure-ownedAttribute-4-upperValue"
                               xmi:type="uml:LiteralUnlimitedNatural">
                     <value>*</value>
                  </upperValue>
                  <association xmi:idref="ddsc.LongDataStructure_has_VariableValueComponent"/>
               </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:id="ddsc.DimensionalDataStructure"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#DimensionalDataStructure"
                              xmi:type="uml:Class">
               <ownedComment xmi:id="ddsc.DimensionalDataStructure-ownedComment"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#DimensionalDataStructure-ownedComment"
                              xmi:type="uml:Comment">
                  <body>Definition
============
Structure of a dimensional data set (organized collection of multidimensional data). It is described by dimension, measure and attribute components.

Examples
==========
The structure described by [City, Average Income, Total Population] where City is a dimension and Average Income and Total Population are measures.</body>
                  <annotatedElement xmi:idref="ddsc.DimensionalDataStructure"/>
               </ownedComment>
               <name>DimensionalDataStructure</name>
               <ownedAttribute xmi:id="ddsc.DimensionalDataStructure-ownedAttribute-1"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#DimensionalDataStructure-ownedAttribute-1"
                                xmi:type="uml:Property">
                  <type xmi:idref="ddsc.IdentifierComponent"/>
                  <upperValue xmi:id="ddsc.DimensionalDataStructure-ownedAttribute-1-upperValue"
                               xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#DimensionalDataStructure-ownedAttribute-1-upperValue"
                               xmi:type="uml:LiteralUnlimitedNatural">
                     <value>*</value>
                  </upperValue>
                  <association xmi:idref="ddsc.DimensionalDataStructure_has_IdentifierComponent"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.DimensionalDataStructure-ownedAttribute-2"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#DimensionalDataStructure-ownedAttribute-2"
                                xmi:type="uml:Property">
                  <type xmi:idref="ddsc.AttributeComponent"/>
                  <upperValue xmi:id="ddsc.DimensionalDataStructure-ownedAttribute-2-upperValue"
                               xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#DimensionalDataStructure-ownedAttribute-2-upperValue"
                               xmi:type="uml:LiteralUnlimitedNatural">
                     <value>*</value>
                  </upperValue>
                  <association xmi:idref="ddsc.DimensionalDataStructure_has_AttributeComponent"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.DimensionalDataStructure-ownedAttribute-3"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#DimensionalDataStructure-ownedAttribute-3"
                                xmi:type="uml:Property">
                  <type xmi:idref="ddsc.MeasureComponent"/>
                  <upperValue xmi:id="ddsc.DimensionalDataStructure-ownedAttribute-3-upperValue"
                               xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#DimensionalDataStructure-ownedAttribute-3-upperValue"
                               xmi:type="uml:LiteralUnlimitedNatural">
                     <value>*</value>
                  </upperValue>
