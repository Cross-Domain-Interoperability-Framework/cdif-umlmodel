                               xmi:type="uml:LiteralUnlimitedNatural">
                     <value>*</value>
                  </upperValue>
                  <association xmi:idref="ddsc.LogicalRecord_has_InstanceVariable"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.LogicalRecord-ownedAttribute-5"
