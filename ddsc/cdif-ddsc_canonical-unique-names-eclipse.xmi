                                xmi:type="uml:Property">
                  <ownedComment xmi:id="ddsc.ReferenceVariable-name-ownedComment"
                                 xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#ReferenceVariable-name-ownedComment"
                                 xmi:type="uml:Comment">
                     <body>Human understandable name (linguistic signifier, word, phrase, or mnemonic). May follow ISO/IEC 11179-5 naming principles, and have context provided to specify usage.</body>
                     <annotatedElement xmi:idref="ddsc.ReferenceVariable-name"/>
                  </ownedComment>
                  <name>name</name>
                  <type xmi:idref="ddsc.ObjectName"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.ReferenceVariable-ownedAttribute-2"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#ReferenceVariable-ownedAttribute-2"
                                xmi:type="uml:Property">
                  <type xmi:idref="ddsc.SubstantiveValueDomain"/>
                  <association xmi:idref="ddsc.ReferenceVariable_takesSubstantiveValuesFrom_SubstantiveValueDomain"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.ReferenceVariable-ownedAttribute-3"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#ReferenceVariable-ownedAttribute-3"
                                xmi:type="uml:Property">
                  <type xmi:idref="ddsc.SentinelValueDomain"/>
                  <upperValue xmi:id="ddsc.ReferenceVariable-ownedAttribute-3-upperValue"
                               xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#ReferenceVariable-ownedAttribute-3-upperValue"
                               xmi:type="uml:LiteralUnlimitedNatural">
                     <value>*</value>
                  </upperValue>
                  <association xmi:idref="ddsc.ReferenceVariable_takesSentinelValuesFrom_SentinelValueDomain"/>
               </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:id="ddsc.DescriptorVariable"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#DescriptorVariable"
                              xmi:type="uml:Class">
               <ownedComment xmi:id="ddsc.DescriptorVariable-ownedComment"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#DescriptorVariable-ownedComment"
                              xmi:type="uml:Comment">
                  <body>Definition
============
Variable that provides codes for variable identification in the context of a data structure.
Variable playing the role of a variable descriptor component.

Examples
==========
Consider two variables, i.e. income and age, with values apearing in the same column. 
Codes "income" and "age" are descriptors that appear in the descriptor value domain corresponding to the descriptor variable.</body>
                  <annotatedElement xmi:idref="ddsc.DescriptorVariable"/>
               </ownedComment>
               <name>DescriptorVariable</name>
               <ownedAttribute xmi:id="ddsc.DescriptorVariable-name"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#DescriptorVariable-name"
                                xmi:type="uml:Property">
                  <ownedComment xmi:id="ddsc.DescriptorVariable-name-ownedComment"
                                 xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#DescriptorVariable-name-ownedComment"
                                 xmi:type="uml:Comment">
                     <body>Human understandable name (linguistic signifier, word, phrase, or mnemonic). May follow ISO/IEC 11179-5 naming principles, and have context provided to specify usage.</body>
                     <annotatedElement xmi:idref="ddsc.DescriptorVariable-name"/>
                  </ownedComment>
                  <name>name</name>
                  <type xmi:idref="ddsc.ObjectName"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.DescriptorVariable-ownedAttribute-2"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#DescriptorVariable-ownedAttribute-2"
                                xmi:type="uml:Property">
                  <type xmi:idref="ddsc.DescriptorValueDomain"/>
                  <upperValue xmi:id="ddsc.DescriptorVariable-ownedAttribute-2-upperValue"
                               xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#DescriptorVariable-ownedAttribute-2-upperValue"
                               xmi:type="uml:LiteralUnlimitedNatural">
                     <value>*</value>
                  </upperValue>
                  <association xmi:idref="ddsc.DescriptorVariable_takesSubstantiveValuesFrom_DescriptorValueDomain"/>
               </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:id="ddsc.SubstantiveValueDomain"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#SubstantiveValueDomain"
                              xmi:type="uml:Class">
               <ownedComment xmi:id="ddsc.SubstantiveValueDomain-ownedComment"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#SubstantiveValueDomain-ownedComment"
                              xmi:type="uml:Comment">
                  <body>Definition 
==========
Value domain for a substantive conceptual domain. Typically a description and/or enumeration of allowed values of interest.  

Examples 
========
All real decimal numbers relating to the subject matter of interest between 0 and 1 specified in Arabic numerals. (From the Generic Statistical Information Model [GSIM] 1.1). The codes "M" male and "F" for female .   

Explanatory notes 
=================
In DDI-CDI the value domain for a variable is separated into "substantive" and "sentinel" values. Substantive values are the values of primary interest. Sentinel values are additional values that may carry supplementary information, such as reasons for missing. This duality is described in ISO 11404. Substantive values for height might be real numbers expressed in meters. The full value domain might also include codes for different kinds of missing values - one code for "refused" and another for "don’t know". Sentinel values may also convey some substantive information and at the same time represent missing values.

An example might be where a numeric variable like number of employees be sometimes a count and sometimes a code representing a range of counts in order to avoid disclosure of information about a specific entity. The substantive value domain may use either a value description, for described values, or a codelist for enumerated values, or both. A value domain may consist of substantive values or sentinel values. Substantive values are those associated directly with some subject matter area. They do not address concerns around processing, such as missing values. Substantive values are called "regular values" in ISO/IEC 11404 - General Purpose Datatypes. The enumerated case is one where all values are listed.

An example is the categorical values for gender: the conceptual domain could consist of the concept of male and the concept of female. These might be represented in codes and associated labels as 1 ("Male") 2 ("Female"). The described case is one where some description is needed to define the set of values. Take the following description for height in meters: "a real number between 0 and 3, represented to two Arabic decimal places". This description might be structured in some way to be machine actionable (datatype="double”, min="0", max="3", decimals="2").</body>
                  <annotatedElement xmi:idref="ddsc.SubstantiveValueDomain"/>
               </ownedComment>
               <name>SubstantiveValueDomain</name>
               <ownedAttribute xmi:id="ddsc.SubstantiveValueDomain-recommendedDataType"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#SubstantiveValueDomain-recommendedDataType"
                                xmi:type="uml:Property">
                  <ownedComment xmi:id="ddsc.SubstantiveValueDomain-recommendedDataType-ownedComment"
                                 xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#SubstantiveValueDomain-recommendedDataType-ownedComment"
                                 xmi:type="uml:Comment">
                     <body>The data types that are recommended for use with this domain.</body>
                     <annotatedElement xmi:idref="ddsc.SubstantiveValueDomain-recommendedDataType"/>
                  </ownedComment>
                  <name>recommendedDataType</name>
                  <type xmi:idref="ddsc.ControlledVocabularyEntry"/>
               </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:id="ddsc.SentinelValueDomain"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#SentinelValueDomain"
                              xmi:type="uml:Class">
               <ownedComment xmi:id="ddsc.SentinelValueDomain-ownedComment"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#SentinelValueDomain-ownedComment"
                              xmi:type="uml:Comment">
                  <body>Definition 
============ 
Value domain for a sentinel conceptual domain.   

Examples 
========== 
Missing categories expressed as codes: -9, refused; -8, Don't Know; for a numeric variable with values greater than zero.    

Explanatory notes 
=================== 
Sentinel values are defined in ISO 11404 as "element of a value space that is not completely consistent with a datatype's properties and characterizing operations...". A common example would be codes for missing values. Sentinel values are used for processing, not to describe subject matter. Typical examples include missing values or invalid entry codes. Sentinel value domains are typically of the enumerated type, but they can be the described type, too. This is not to say that sentinel values carry no information. Data on gender might be enumerated by "0, male" and "1, female". These are the substantive values (see substantive value domain). However, there may be the need to include missing values along with that data, such as "m, missing" and "r, refused". These are sentinel values.  ISO/IEC 11404 - General Purpose Datatypes, defines sentinel values in terms of how that standard defines datatypes. But, the fact that the sentinels don't fit in terms of the calculations and statistics one would perform on the "clean" data is a distinguishing characteristic. In the example above, one would not include missing or refused data in calculating a ratio of females to the total population. Sentinel values may be described rather than enumerated. For instance, there might be a range of values, each representing an out of range value, but there could be too many to enumerate. It is easier to describe the range.  In some software missing values are represented as values not in the datatype of the valid values. R has values of NA, NaN, Inf, and -Inf. SAS and Stata have values displayed as ".", ".A" through ".Z", and "._"  Other software might use values like 999 for missing that would otherwise be the same datatype as valid values but outside the parameters of the domain. In the gender example above: For SPSS the sentinel values might be represented as: 998 = "refused" 999 = "not recorded"  For SAS or Stata the sentinel values might be represented as: .R = "refused" .N = "not recorded"  Sentinel values can also be used for other purposes beyond missing. For a numeric variable "A" might represent a value somewhere in a defined range to prevent disclosure of information about an individual. This might be considered a "semi-missing value". In SAS or Stata for example: .A = "greater than or equal to 100 and less than 1000 ".</body>
                  <annotatedElement xmi:idref="ddsc.SentinelValueDomain"/>
               </ownedComment>
               <name>SentinelValueDomain</name>
               <ownedAttribute xmi:id="ddsc.SentinelValueDomain-recommendedDataType"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#SentinelValueDomain-recommendedDataType"
                                xmi:type="uml:Property">
                  <ownedComment xmi:id="ddsc.SentinelValueDomain-recommendedDataType-ownedComment"
                                 xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#SentinelValueDomain-recommendedDataType-ownedComment"
                                 xmi:type="uml:Comment">
                     <body>The data types that are recommended for use with this domain.</body>
                     <annotatedElement xmi:idref="ddsc.SentinelValueDomain-recommendedDataType"/>
                  </ownedComment>
                  <name>recommendedDataType</name>
                  <type xmi:idref="ddsc.ControlledVocabularyEntry"/>
               </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:id="ddsc.DescriptorValueDomain"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#DescriptorValueDomain"
                              xmi:type="uml:Class">
               <ownedComment xmi:id="ddsc.DescriptorValueDomain-ownedComment"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#DescriptorValueDomain-ownedComment"
                              xmi:type="uml:Comment">
                  <body>Definition
============
Set of permissible values for a variable playing the role of a variable descriptor component.

Examples
==========
Consider two variables, i.e. income and age, with values appearing in the same column. 
Codes "income" and "age" are descriptors that appear in the descriptor value domain corresponding to the descriptor variable.</body>
                  <annotatedElement xmi:idref="ddsc.DescriptorValueDomain"/>
               </ownedComment>
               <name>DescriptorValueDomain</name>
            </packagedElement>
            <packagedElement xmi:id="ddsc.Descriptor"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#Descriptor"
                              xmi:type="uml:Class">
               <ownedComment xmi:id="ddsc.Descriptor-ownedComment"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#Descriptor-ownedComment"
                              xmi:type="uml:Comment">
                  <body>Definition
==========
Use of a code for variable identification in the context of a data structure and a variable descriptor component.

Examples
========
Consider two variables, i.e. income and age, with values appearing in the same column. Codes "income" and "age" are descriptors. They appear multiple time in a variable descriptor component, one for each value in the variable value component. Each descriptor references one of those values. This way it's possible to identify which values correspond to income and which ones to age.</body>
                  <annotatedElement xmi:idref="ddsc.Descriptor"/>
               </ownedComment>
               <name>Descriptor</name>
               <ownedAttribute xmi:id="ddsc.Descriptor-content"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#Descriptor-content"
                                xmi:type="uml:Property">
                  <ownedComment xmi:id="ddsc.Descriptor-content-ownedComment"
                                 xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#Descriptor-content-ownedComment"
                                 xmi:type="uml:Comment">
                     <body>The content of this value expressed as a string.</body>
                     <annotatedElement xmi:idref="ddsc.Descriptor-content"/>
                  </ownedComment>
                  <name>content</name>
                  <type xmi:idref="ddsc.TypedString"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.Descriptor-ownedAttribute-2"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#Descriptor-ownedAttribute-2"
                                xmi:type="uml:Property">
                  <type xmi:idref="ddsc.InstanceVariable"/>
                  <upperValue xmi:id="ddsc.Descriptor-ownedAttribute-2-upperValue"
                               xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#Descriptor-ownedAttribute-2-upperValue"
                               xmi:type="uml:LiteralUnlimitedNatural">
                     <value>*</value>
                  </upperValue>
                  <association xmi:idref="ddsc.Descriptor_identifies_InstanceVariable"/>
               </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:id="ddsc.UnitType"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#UnitType"
                              xmi:type="uml:Class">
               <ownedComment xmi:id="ddsc.UnitType-ownedComment"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#UnitType-ownedComment"
                              xmi:type="uml:Comment">
                  <body>Definition
==========
Unit type is a type or class of objects of interest (units).

Examples
========
Person, Establishment, Household, State, Country, Dog, Automobile, Neutrino.

Explanatory notes
=================
Unit type is the most general in the hierarchy of unit type, universe, and population. It is a description of the basic characteristics for a general set of Units. A universe is a set of entities defined by a specialization of a unit type. A Population further narrows the specification to a specific time and geography.

A unit type is used to describe a class or group of Units based on a single characteristic with no specification of time and geography. For example, the unit type of "Person" groups together a set of Units based on the characteristic that they are "Persons".

It concerns not only unit types used in dissemination, but anywhere in the statistical process. E.g. using administrative data might involve the use of a fiscal unit. [GSIM 1.1].</body>
                  <annotatedElement xmi:idref="ddsc.UnitType"/>
               </ownedComment>
               <name>UnitType</name>
               <ownedAttribute xmi:id="ddsc.UnitType-name"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#UnitType-name"
                                xmi:type="uml:Property">
                  <ownedComment xmi:id="ddsc.UnitType-name-ownedComment"
                                 xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#UnitType-name-ownedComment"
                                 xmi:type="uml:Comment">
                     <body>Human understandable name (linguistic signifier, word, phrase, or mnemonic). May follow ISO/IEC 11179-5 naming principles, and have context provided to specify usage.</body>
                     <annotatedElement xmi:idref="ddsc.UnitType-name"/>
                  </ownedComment>
                  <name>name</name>
                  <type xmi:idref="ddsc.ObjectName"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.UnitType-descriptiveText"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#UnitType-descriptiveText"
                                xmi:type="uml:Property">
                  <ownedComment xmi:id="ddsc.UnitType-descriptiveText-ownedComment"
                                 xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#UnitType-descriptiveText-ownedComment"
                                 xmi:type="uml:Comment">
                     <body>A short natural language account of the characteristics of the object.</body>
                     <annotatedElement xmi:idref="ddsc.UnitType-descriptiveText"/>
                  </ownedComment>
                  <name>descriptiveText</name>
                  <type xmi:idref="ddsc.InternationalString"/>
               </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:id="ddsc.Universe"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#Universe"
                              xmi:type="uml:Class">
               <ownedComment xmi:id="ddsc.Universe-ownedComment"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#Universe-ownedComment"
                              xmi:type="uml:Comment">
                  <body>Definition
============
Specialized unit type, with the specialization based upon characteristics other than time and geography.

Examples
==========
1. Canadian adults (not limited to those residing in Canada)
2. Computer companies 
3. Universities

Explanatory notes
===================
Universe sits in a hierarchy between unit type and population, with unit type being most general and Population most specific. A universe is a set of entities defined by a more narrow specification than that of an underlying unit type. A population further narrows the specification to a specific time and geography.

If the Universe consists of people, a number of factors may be used in defining membership in the Universe, such as age, sex, residence, income, veteran status, criminal convictions, etc. The universe may consist of elements other than persons, such as housing units, court cases, deaths, countries, etc. A universe may be described as "inclusive" or "exclusive". 

Not to be confused with Population, which includes the specification of time and geography.</body>
                  <annotatedElement xmi:idref="ddsc.Universe"/>
               </ownedComment>
               <name>Universe</name>
               <ownedAttribute xmi:id="ddsc.Universe-name"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#Universe-name"
                                xmi:type="uml:Property">
                  <ownedComment xmi:id="ddsc.Universe-name-ownedComment"
                                 xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#Universe-name-ownedComment"
                                 xmi:type="uml:Comment">
                     <body>Human understandable name (linguistic signifier, word, phrase, or mnemonic). May follow ISO/IEC 11179-5 naming principles, and have context provided to specify usage.</body>
                     <annotatedElement xmi:idref="ddsc.Universe-name"/>
                  </ownedComment>
                  <name>name</name>
                  <type xmi:idref="ddsc.ObjectName"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.Universe-descriptiveText"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#Universe-descriptiveText"
                                xmi:type="uml:Property">
                  <ownedComment xmi:id="ddsc.Universe-descriptiveText-ownedComment"
                                 xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#Universe-descriptiveText-ownedComment"
                                 xmi:type="uml:Comment">
                     <body>A short natural language account of the characteristics of the object.</body>
                     <annotatedElement xmi:idref="ddsc.Universe-descriptiveText"/>
                  </ownedComment>
                  <name>descriptiveText</name>
                  <type xmi:idref="ddsc.InternationalString"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.Universe-ownedAttribute-3"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#Universe-ownedAttribute-3"
                                xmi:type="uml:Property">
                  <type xmi:idref="ddsc.UnitType"/>
                  <upperValue xmi:id="ddsc.Universe-ownedAttribute-3-upperValue"
                               xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#Universe-ownedAttribute-3-upperValue"
                               xmi:type="uml:LiteralUnlimitedNatural">
                     <value>*</value>
                  </upperValue>
                  <association xmi:idref="ddsc.Universe_uses_UnitType"/>
               </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:id="ddsc.Population"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#Population"
                              xmi:type="uml:Class">
               <ownedComment xmi:id="ddsc.Population-ownedComment"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#Population-ownedComment"
                              xmi:type="uml:Comment">
                  <body>Definition
============
Universe with time and geography specified.

Examples
==========
1. Canadian adult persons residing in Canada on 13 November 1956.
2. US computer companies at the end of 2012.  
3. Universities in Denmark 1 January 2011.

Explanatory notes
===================
Population is the most specific in the conceptually narrowing hierarchy of unit type, universe and population. Several populations having differing time and or geography may specialize the same universe.</body>
                  <annotatedElement xmi:idref="ddsc.Population"/>
               </ownedComment>
               <name>Population</name>
               <ownedAttribute xmi:id="ddsc.Population-name"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#Population-name"
                                xmi:type="uml:Property">
                  <ownedComment xmi:id="ddsc.Population-name-ownedComment"
                                 xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#Population-name-ownedComment"
                                 xmi:type="uml:Comment">
                     <body>Human understandable name (linguistic signifier, word, phrase, or mnemonic). May follow ISO/IEC 11179-5 naming principles, and have context provided to specify usage.</body>
                     <annotatedElement xmi:idref="ddsc.Population-name"/>
                  </ownedComment>
                  <name>name</name>
                  <type xmi:idref="ddsc.ObjectName"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.Population-descriptiveText"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#Population-descriptiveText"
                                xmi:type="uml:Property">
                  <ownedComment xmi:id="ddsc.Population-descriptiveText-ownedComment"
                                 xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#Population-descriptiveText-ownedComment"
                                 xmi:type="uml:Comment">
                     <body>A short natural language account of the characteristics of the object.</body>
                     <annotatedElement xmi:idref="ddsc.Population-descriptiveText"/>
                  </ownedComment>
                  <name>descriptiveText</name>
                  <type xmi:idref="ddsc.InternationalString"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.Population-ownedAttribute-3"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#Population-ownedAttribute-3"
                                xmi:type="uml:Property">
                  <type xmi:idref="ddsc.Universe"/>
                  <upperValue xmi:id="ddsc.Population-ownedAttribute-3-upperValue"
                               xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#Population-ownedAttribute-3-upperValue"
                               xmi:type="uml:LiteralUnlimitedNatural">
                     <value>2</value>
                  </upperValue>
                  <association xmi:idref="ddsc.Population_uses_Universe"/>
               </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:id="ddsc.IdentifierComponent"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#IdentifierComponent"
                              xmi:type="uml:Class">
               <ownedComment xmi:id="ddsc.IdentifierComponent-ownedComment"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#IdentifierComponent-ownedComment"
                              xmi:type="uml:Comment">
                  <body>Definition 
============ 
Role given to a represented variable in the context of a long or wide data structure to identify the units associated to data points, and in dimensional and key value data structures to provide identifying fields for the instance values.  

Examples 
========== 
The personal identification number of a Swedish citizen for unit data or the name of a country in the European Union for dimensional data.</body>
                  <annotatedElement xmi:idref="ddsc.IdentifierComponent"/>
               </ownedComment>
               <name>IdentifierComponent</name>
               <ownedAttribute xmi:id="ddsc.IdentifierComponent-ownedAttribute-1"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#IdentifierComponent-ownedAttribute-1"
                                xmi:type="uml:Property">
                  <type xmi:idref="ddsc.InstanceVariable"/>
                  <association xmi:idref="ddsc.IdentifierComponent_isDefinedBy_InstanceVariable"/>
               </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:id="ddsc.MeasureComponent"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#MeasureComponent"
                              xmi:type="uml:Class">
               <ownedComment xmi:id="ddsc.MeasureComponent-ownedComment"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#MeasureComponent-ownedComment"
                              xmi:type="uml:Comment">
                  <body>Definition 
============ 
Role given to a represented variable in the context of a data structure to hold the observed/derived values.  

Examples 
========== 
Height of a person in a wide or long dataset or number of citizens in a country in a dataset for multiple countries (dimensional dataset).</body>
                  <annotatedElement xmi:idref="ddsc.MeasureComponent"/>
               </ownedComment>
               <name>MeasureComponent</name>
               <ownedAttribute xmi:id="ddsc.MeasureComponent-ownedAttribute-1"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#MeasureComponent-ownedAttribute-1"
                                xmi:type="uml:Property">
                  <type xmi:idref="ddsc.InstanceVariable"/>
                  <association xmi:idref="ddsc.MeasureComponent_isDefinedBy_InstanceVariable"/>
               </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:id="ddsc.AttributeComponent"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#AttributeComponent"
                              xmi:type="uml:Class">
               <ownedComment xmi:id="ddsc.AttributeComponent-ownedComment"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#AttributeComponent-ownedComment"
                              xmi:type="uml:Comment">
                  <body>Definition 
============ 
Role given to a represented variable in the context of a data structure to qualify observations or provide other types of supplementary information.  

Examples 
========== 
The publication status of an observation (e.g. provisional, final, revised).</body>
                  <annotatedElement xmi:idref="ddsc.AttributeComponent"/>
               </ownedComment>
               <name>AttributeComponent</name>
               <ownedAttribute xmi:id="ddsc.AttributeComponent-ownedAttribute-1"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#AttributeComponent-ownedAttribute-1"
                                xmi:type="uml:Property">
                  <type xmi:idref="ddsc.InstanceVariable"/>
                  <association xmi:idref="ddsc.AttributeComponent_isDefinedBy_InstanceVariable"/>
               </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:id="ddsc.DimensionComponent"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#DimensionComponent"
                              xmi:type="uml:Class">
               <ownedComment xmi:id="ddsc.DimensionComponent-ownedComment"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#DimensionComponent-ownedComment"
                              xmi:type="uml:Comment">
                  <body>Definition 
============ 
Role given to a represented variable in the context of a dimensional data structure to identify the universes associated with data points. The variable acts as a field in the compound identifier (the key structure) to disambiguate the cells in the multi-dimensional "cube".  

Explanatory notes 
=================== 
The categories from each dimension often are used in combination to identify a cell. The meaning of the combination of the categories supplies meaning to the cell.</body>
                  <annotatedElement xmi:idref="ddsc.DimensionComponent"/>
               </ownedComment>
               <name>DimensionComponent</name>
               <ownedAttribute xmi:id="ddsc.DimensionComponent-ownedAttribute-1"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#DimensionComponent-ownedAttribute-1"
                                xmi:type="uml:Property">
                  <type xmi:idref="ddsc.InstanceVariable"/>
                  <association xmi:idref="ddsc.DimensionComponent_isDefinedBy_InstanceVariable"/>
               </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:id="ddsc.ComponentPosition"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#ComponentPosition"
                              xmi:type="uml:Class">
               <ownedComment xmi:id="ddsc.ComponentPosition-ownedComment"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#ComponentPosition-ownedComment"
                              xmi:type="uml:Comment">
                  <body>Definition 
============ 
Indexes the components in a data structure using integers with a position indicated by incrementing upward from 0 or 1.</body>
                  <annotatedElement xmi:idref="ddsc.ComponentPosition"/>
               </ownedComment>
               <name>ComponentPosition</name>
               <ownedAttribute xmi:id="ddsc.ComponentPosition-value"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#ComponentPosition-value"
                                xmi:type="uml:Property">
                  <ownedComment xmi:id="ddsc.ComponentPosition-value-ownedComment"
                                 xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#ComponentPosition-value-ownedComment"
                                 xmi:type="uml:Comment">
                     <body>Index value of the member in an ordered array.</body>
                     <annotatedElement xmi:idref="ddsc.ComponentPosition-value"/>
                  </ownedComment>
                  <name>value</name>
                  <type xmi:type="uml:PrimitiveType"
                         href="http://www.eclipse.org/uml2/5.0.0/UML/PrimitiveTypes.xmi#Integer"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.ComponentPosition-ownedAttribute-2"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#ComponentPosition-ownedAttribute-2"
                                xmi:type="uml:Property">
                  <type xmi:idref="ddsc.DimensionComponent"/>
                  <association xmi:idref="ddsc.ComponentPosition_indexes_DimensionComponent"/>
               </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:id="ddsc.PrimaryKey"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PrimaryKey"
                              xmi:type="uml:Class">
               <ownedComment xmi:id="ddsc.PrimaryKey-ownedComment"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PrimaryKey-ownedComment"
                              xmi:type="uml:Comment">
                  <body>Definition
============
Role of a set of data structure components for content linkage purposes

Explanatory notes
===================
Equivalent to primary key in the relational model.
A primary key essentially indicates which data structure components correspond to key members.
It can also be used in conjunction with foreign key to link data structures and their related datasets.</body>
                  <annotatedElement xmi:idref="ddsc.PrimaryKey"/>
               </ownedComment>
               <name>PrimaryKey</name>
               <ownedAttribute xmi:id="ddsc.PrimaryKey-ownedAttribute-1"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PrimaryKey-ownedAttribute-1"
                                xmi:type="uml:Property">
                  <type xmi:idref="ddsc.PrimaryKeyComponent"/>
                  <upperValue xmi:id="ddsc.PrimaryKey-ownedAttribute-1-upperValue"
                               xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PrimaryKey-ownedAttribute-1-upperValue"
                               xmi:type="uml:LiteralUnlimitedNatural">
                     <value>*</value>
                  </upperValue>
                  <association xmi:idref="ddsc.PrimaryKey_isComposedOf_PrimaryKeyComponent"/>
               </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:id="ddsc.PrimaryKeyComponent"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PrimaryKeyComponent"
                              xmi:type="uml:Class">
               <ownedComment xmi:id="ddsc.PrimaryKeyComponent-ownedComment"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PrimaryKeyComponent-ownedComment"
                              xmi:type="uml:Comment">
                  <body>Definition
============
Role of a data structure component for content identification purposes

Explanatory notes
===================
Equivalent to a primary key attribute (i.e. column) in the relational model.
It can be used in conjunction with a foreign key component to link data structures and their related datasets.</body>
                  <annotatedElement xmi:idref="ddsc.PrimaryKeyComponent"/>
               </ownedComment>
               <name>PrimaryKeyComponent</name>
               <ownedAttribute xmi:id="ddsc.PrimaryKeyComponent-ownedAttribute-1"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PrimaryKeyComponent-ownedAttribute-1"
                                xmi:type="uml:Property">
                  <type xmi:idref="ddsc.IdentifierComponent"/>
                  <association xmi:idref="ddsc.PrimaryKeyComponent_correspondsTo_IdentifierComponent"/>
               </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:id="ddsc.VariableValueComponent"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#VariableValueComponent"
                              xmi:type="uml:Class">
               <ownedComment xmi:id="ddsc.VariableValueComponent-ownedComment"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#VariableValueComponent-ownedComment"
                              xmi:type="uml:Comment">
                  <body>Definition 
============ 
Role given to a represented variable in the context of a data structure to record values of multiple variables.   

Examples 
========== 
Consider two variables, i.e. income and age, with their values living together in different entries in the same column.  The values of those two variables are now in the value domain of a single variable (the one working as a variable value component).  Another column, based on a variable descriptor component, use codes for "income" and "age" to distinguish income values from age values.   

Explanatory notes 
=================== 
A variable value component captures the values of multiple variables that have been transposed into a single column.  The variable descriptor component provides a mechanism to identify which of those values correspond to which variable.   This structure provides a flexible mechanism avoiding the need for a formal pointer.</body>
                  <annotatedElement xmi:idref="ddsc.VariableValueComponent"/>
               </ownedComment>
               <name>VariableValueComponent</name>
               <ownedAttribute xmi:id="ddsc.VariableValueComponent-ownedAttribute-1"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#VariableValueComponent-ownedAttribute-1"
                                xmi:type="uml:Property">
                  <type xmi:idref="ddsc.ReferenceVariable"/>
                  <association xmi:idref="ddsc.VariableValueComponent_isDefinedBy_ReferenceVariable"/>
               </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:id="ddsc.VariableDescriptorComponent"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#VariableDescriptorComponent"
                              xmi:type="uml:Class">
               <ownedComment xmi:id="ddsc.VariableDescriptorComponent-ownedComment"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#VariableDescriptorComponent-ownedComment"
                              xmi:type="uml:Comment">
                  <body>Definition 
============ 
Role given to a represented variable in the context of a data structure to provide codes for variable identification.   

Examples 
========== 
Consider {"income", "age"} to be the value domain of the represented variable working as a variable descriptor component.  The two codes, i.e. those designating "income" and "age", are descriptors used to identify which values in the variable value component correspond to income and which ones to age.   

Explanatory notes 
=================== 
Whenever more than one variable appears in the same column, we need a mechanism to distinguish which values correspond to which variable. This mechanism is provided by the variable descriptor component, which contains the codes used to link the variables to their values.  This structure provides a flexible mechanism avoiding the need for a formal pointer.</body>
                  <annotatedElement xmi:idref="ddsc.VariableDescriptorComponent"/>
               </ownedComment>
               <name>VariableDescriptorComponent</name>
               <ownedAttribute xmi:id="ddsc.VariableDescriptorComponent-ownedAttribute-1"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#VariableDescriptorComponent-ownedAttribute-1"
                                xmi:type="uml:Property">
                  <type xmi:idref="ddsc.VariableValueComponent"/>
                  <association xmi:idref="ddsc.VariableDescriptorComponent_refersTo_VariableValueComponent"/>
               </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:id="ddsc.PhysicalSegmentLayout"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PhysicalSegmentLayout"
                              xmi:type="uml:Class">
               <ownedComment xmi:id="ddsc.PhysicalSegmentLayout-ownedComment"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PhysicalSegmentLayout-ownedComment"
                              xmi:type="uml:Comment">
                  <body>Definition 
============ 
Used as an extension point in the description of the different layout styles of data structure descriptions.  

Examples 
========== 
Examples include unit segment layouts, event data layouts, and cube layouts (e.g. summary data).  

Explanatory notes 
=================== 
A physical segment layout is a physical description (e.g. unit segment layout) of the associated logical record Layout consisting of a collection of value mappings describing the physical interrelationship of each related value mapping and associated instance variable.</body>
                  <annotatedElement xmi:idref="ddsc.PhysicalSegmentLayout"/>
               </ownedComment>
               <name>PhysicalSegmentLayout</name>
               <ownedAttribute xmi:id="ddsc.PhysicalSegmentLayout-delimiter"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PhysicalSegmentLayout-delimiter"
                                xmi:type="uml:Property">
                  <ownedComment xmi:id="ddsc.PhysicalSegmentLayout-delimiter-ownedComment"
                                 xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PhysicalSegmentLayout-delimiter-ownedComment"
                                 xmi:type="uml:Comment">
                     <body>The Delimiting character in the data. Must be used if isDelimited is True. "The separator between cells, set by the delimiter property of a dialect description. The default is ,. See the W3C Recommendation "Metadata Vocabulary for Tabular Data" (https://www.w3.org/TR/tabular-data-model/#encoding). From the "CSV Dialect" specification (https://specs.frictionlessdata.io/csv-dialect/#specification): "delimiter: specifies a one-character string to use as the field separator. Default = ,."</body>
                     <annotatedElement xmi:idref="ddsc.PhysicalSegmentLayout-delimiter"/>
                  </ownedComment>
                  <name>delimiter</name>
                  <type xmi:type="uml:PrimitiveType"
                         href="http://www.eclipse.org/uml2/5.0.0/UML/PrimitiveTypes.xmi#String"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.PhysicalSegmentLayout-encoding"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PhysicalSegmentLayout-encoding"
                                xmi:type="uml:Property">
                  <ownedComment xmi:id="ddsc.PhysicalSegmentLayout-encoding-ownedComment"
                                 xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PhysicalSegmentLayout-encoding-ownedComment"
                                 xmi:type="uml:Comment">
                     <body>The character encoding of the represented data. From the W3C Recommendation "Metadata Vocabulary for Tabular Data" (https://www.w3.org/TR/tabular-metadata/) 5.9 Dialect: "encoding - An atomic property that sets the encoding flag to the single provided string value, which MUST be a defined in [encoding]. The default is 'utf-8'." From the same W3C recommendation 7.2 Encoding: "CSV files should be encoded using UTF-8, and should be in Unicode Normal Form C as defined in [UAX15]. If a CSV file is not encoded using UTF-8, the encoding should be specified through the charset parameter in the Content-Type header."</body>
                     <annotatedElement xmi:idref="ddsc.PhysicalSegmentLayout-encoding"/>
                  </ownedComment>
                  <name>encoding</name>
                  <type xmi:idref="ddsc.ControlledVocabularyEntry"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.PhysicalSegmentLayout-escapeCharacter"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PhysicalSegmentLayout-escapeCharacter"
                                xmi:type="uml:Property">
                  <ownedComment xmi:id="ddsc.PhysicalSegmentLayout-escapeCharacter-ownedComment"
                                 xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PhysicalSegmentLayout-escapeCharacter-ownedComment"
                                 xmi:type="uml:Comment">
                     <body>"The string that is used to escape the quote character within escaped cells, or null" see https://www.w3.org/TR/tabular-data-model/#encoding. From https://www.w3.org/TR/tabular-metadata/ 5.9 Dialect "doubleQuote: A boolean atomic property that, if true, sets the escape character flag to ". If false, to \. The default is true." From http://specs.frictionlessdata.io/csv-dialect/ "doubleQuote: controls the handling of quotes inside fields. If true, two consecutive quotes should be interpreted as one. Default = true".</body>
                     <annotatedElement xmi:idref="ddsc.PhysicalSegmentLayout-escapeCharacter"/>
                  </ownedComment>
                  <name>escapeCharacter</name>
                  <type xmi:type="uml:PrimitiveType"
                         href="http://www.eclipse.org/uml2/5.0.0/UML/PrimitiveTypes.xmi#String"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.PhysicalSegmentLayout-hasHeader"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PhysicalSegmentLayout-hasHeader"
                                xmi:type="uml:Property">
                  <ownedComment xmi:id="ddsc.PhysicalSegmentLayout-hasHeader-ownedComment"
                                 xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PhysicalSegmentLayout-hasHeader-ownedComment"
                                 xmi:type="uml:Comment">
                     <body>True if the file contains a header containing column names. From https://www.w3.org/TR/tabular-metadata/ 5.9 Dialect "header: A boolean atomic property that, if true, sets the header row count flag to 1, and if false to 0, unless headerRowCount is provided, in which case the value provided for the header property is ignored. The default is true." From http://specs.frictionlessdata.io/csv-dialect/ "header: indicates whether the file includes a header row. If true the first row in the file is a header row, not data. Default = true".</body>
                     <annotatedElement xmi:idref="ddsc.PhysicalSegmentLayout-hasHeader"/>
                  </ownedComment>
                  <name>hasHeader</name>
                  <type xmi:type="uml:PrimitiveType"
                         href="http://www.eclipse.org/uml2/5.0.0/UML/PrimitiveTypes.xmi#Boolean"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.PhysicalSegmentLayout-headerRowCount"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PhysicalSegmentLayout-headerRowCount"
                                xmi:type="uml:Property">
                  <ownedComment xmi:id="ddsc.PhysicalSegmentLayout-headerRowCount-ownedComment"
                                 xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PhysicalSegmentLayout-headerRowCount-ownedComment"
                                 xmi:type="uml:Comment">
                     <body>The number of lines in the header From https://www.w3.org/TR/tabular-metadata/ 5.9 Dialect "headerRowCount: A numeric atomic property that sets the header row count flag to the single provided value, which MUST be a non-negative integer. The default is 1."</body>
                     <annotatedElement xmi:idref="ddsc.PhysicalSegmentLayout-headerRowCount"/>
                  </ownedComment>
                  <name>headerRowCount</name>
                  <type xmi:type="uml:PrimitiveType"
                         href="http://www.eclipse.org/uml2/5.0.0/UML/PrimitiveTypes.xmi#Integer"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.PhysicalSegmentLayout-isDelimited"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PhysicalSegmentLayout-isDelimited"
                                xmi:type="uml:Property">
                  <ownedComment xmi:id="ddsc.PhysicalSegmentLayout-isDelimited-ownedComment"
                                 xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PhysicalSegmentLayout-isDelimited-ownedComment"
                                 xmi:type="uml:Comment">
                     <body>Indicates whether the data are in a delimited format. If "true," the format is delimited, and the isFixedWidth property must be set to "false." If not set to "true," the property isFixedWitdh must be set to "true."</body>
                     <annotatedElement xmi:idref="ddsc.PhysicalSegmentLayout-isDelimited"/>
                  </ownedComment>
                  <name>isDelimited</name>
                  <type xmi:type="uml:PrimitiveType"
                         href="http://www.eclipse.org/uml2/5.0.0/UML/PrimitiveTypes.xmi#Boolean"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.PhysicalSegmentLayout-isFixedWidth"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PhysicalSegmentLayout-isFixedWidth"
                                xmi:type="uml:Property">
                  <ownedComment xmi:id="ddsc.PhysicalSegmentLayout-isFixedWidth-ownedComment"
                                 xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PhysicalSegmentLayout-isFixedWidth-ownedComment"
                                 xmi:type="uml:Comment">
                     <body>Set to true if the file is fixed-width. If true, isDelimited must be set to false.</body>
                     <annotatedElement xmi:idref="ddsc.PhysicalSegmentLayout-isFixedWidth"/>
                  </ownedComment>
                  <name>isFixedWidth</name>
                  <type xmi:type="uml:PrimitiveType"
                         href="http://www.eclipse.org/uml2/5.0.0/UML/PrimitiveTypes.xmi#Boolean"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.PhysicalSegmentLayout-lineTerminator"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PhysicalSegmentLayout-lineTerminator"
                                xmi:type="uml:Property">
                  <ownedComment xmi:id="ddsc.PhysicalSegmentLayout-lineTerminator-ownedComment"
                                 xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PhysicalSegmentLayout-lineTerminator-ownedComment"
                                 xmi:type="uml:Comment">
                     <body>The strings that can be used at the end of a row, set by the lineTerminators property of a dialect description. The default is [CRLF, LF]. See the W3C Recommendation "Metadata Vocabulary for Tabular Data" (https://www.w3.org/TR/tabular-data-model/#encoding) 5.9 Dialect "lineTerminators: An atomic property that sets the line terminators flag to either an array containing the single provided string value, or the provided array. The default is ['rn', 'n']." Also, from the "CSV Dialect" specification (http://specs.frictionlessdata.io/csv-dialect/): "lineTerminator: specifies the character sequence which should terminate rows. Default = rn."</body>
                     <annotatedElement xmi:idref="ddsc.PhysicalSegmentLayout-lineTerminator"/>
                  </ownedComment>
                  <name>lineTerminator</name>
                  <type xmi:type="uml:PrimitiveType"
                         href="http://www.eclipse.org/uml2/5.0.0/UML/PrimitiveTypes.xmi#String"/>
                  <upperValue xmi:id="ddsc.PhysicalSegmentLayout-lineTerminator-upperValue"
                               xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PhysicalSegmentLayout-lineTerminator-upperValue"
                               xmi:type="uml:LiteralUnlimitedNatural">
                     <value>*</value>
                  </upperValue>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.PhysicalSegmentLayout-quoteCharacter"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PhysicalSegmentLayout-quoteCharacter"
                                xmi:type="uml:Property">
                  <ownedComment xmi:id="ddsc.PhysicalSegmentLayout-quoteCharacter-ownedComment"
                                 xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PhysicalSegmentLayout-quoteCharacter-ownedComment"
                                 xmi:type="uml:Comment">
                     <body>"The string that is used around escaped cells, or null, set by the quoteChar property of a dialect description. The default is ".". See W3C Recommendation "Model for Tabular Data and Metadata on the Web", https://www.w3.org/TR/tabular-data-model/#parsing. From the W3C Recommendation "Metadata Vocabulary for Tabular Data" (https://www.w3.org/TR/tabular-metadata/) 5.9 Dialect: "quoteChar: An atomic property that sets the quote character flag to the single provided value, which MUST be a string or null. If the value is null, the escape character flag is also set to null. The default is '"'." From the CSV Dialect specification (http://specs.frictionlessdata.io/csv-dialect/): "quoteChar: specifies a one-character string to use as the quoting character. Default = "."</body>
                     <annotatedElement xmi:idref="ddsc.PhysicalSegmentLayout-quoteCharacter"/>
                  </ownedComment>
                  <name>quoteCharacter</name>
                  <type xmi:type="uml:PrimitiveType"
                         href="http://www.eclipse.org/uml2/5.0.0/UML/PrimitiveTypes.xmi#String"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.PhysicalSegmentLayout-skipInitialSpace"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PhysicalSegmentLayout-skipInitialSpace"
                                xmi:type="uml:Property">
                  <ownedComment xmi:id="ddsc.PhysicalSegmentLayout-skipInitialSpace-ownedComment"
                                 xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PhysicalSegmentLayout-skipInitialSpace-ownedComment"
                                 xmi:type="uml:Comment">
                     <body>If the value is True, skip whitespace at the beginning of a line or following a delimiter. From the W3C Recommendation "Metadata Vocabulary for Tabular Data" (https://www.w3.org/TR/tabular-metadata/) 5.9 Dialect: "skipInitialSpace: A boolean atomic property that, if true, sets the trim flag to 'start' and if false, to false. If the trim property is provided, the skipInitialSpace property is ignored. The default is false." From the CSV Dialect specification (http://specs.frictionlessdata.io/csv-dialect/): "skipInitialSpace: specifies how to interpret whitespace which immediately follows a delimiter; if false, it means that whitespace immediately after a delimiter should be treated as part of the following field. Default = true."</body>
                     <annotatedElement xmi:idref="ddsc.PhysicalSegmentLayout-skipInitialSpace"/>
                  </ownedComment>
                  <name>skipInitialSpace</name>
                  <type xmi:type="uml:PrimitiveType"
                         href="http://www.eclipse.org/uml2/5.0.0/UML/PrimitiveTypes.xmi#Boolean"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.PhysicalSegmentLayout-trim"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PhysicalSegmentLayout-trim"
                                xmi:type="uml:Property">
                  <ownedComment xmi:id="ddsc.PhysicalSegmentLayout-trim-ownedComment"
                                 xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PhysicalSegmentLayout-trim-ownedComment"
                                 xmi:type="uml:Comment">
                     <body>Specifies which spaces to remove from a data value (start, end, both, neither) From the W3C Recommendation "Metadata Vocabulary for Tabular Data" (https://www.w3.org/TR/tabular-metadata/) 5.9 Dialect: "trim: An atomic property that, if the boolean true, sets the trim flag to true and if the boolean false to false. If the value provided is a string, sets the trim flag to the provided value, which MUST be one of 'true', 'false', 'start', or 'end'. The default is true."</body>
                     <annotatedElement xmi:idref="ddsc.PhysicalSegmentLayout-trim"/>
                  </ownedComment>
                  <name>trim</name>
                  <type xmi:idref="ddsc.TrimValues"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.PhysicalSegmentLayout-ownedAttribute-12"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PhysicalSegmentLayout-ownedAttribute-12"
                                xmi:type="uml:Property">
                  <type xmi:idref="ddsc.LogicalRecord"/>
                  <association xmi:idref="ddsc.PhysicalSegmentLayout_formats_LogicalRecord"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.PhysicalSegmentLayout-ownedAttribute-13"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PhysicalSegmentLayout-ownedAttribute-13"
                                xmi:type="uml:Property">
                  <type xmi:idref="ddsc.ValueMapping"/>
                  <upperValue xmi:id="ddsc.PhysicalSegmentLayout-ownedAttribute-13-upperValue"
                               xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PhysicalSegmentLayout-ownedAttribute-13-upperValue"
                               xmi:type="uml:LiteralUnlimitedNatural">
                     <value>*</value>
                  </upperValue>
                  <association xmi:idref="ddsc.PhysicalSegmentLayout_has_ValueMapping"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.PhysicalSegmentLayout-ownedAttribute-14"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PhysicalSegmentLayout-ownedAttribute-14"
                                xmi:type="uml:Property">
                  <type xmi:idref="ddsc.ValueMappingPosition"/>
                  <upperValue xmi:id="ddsc.PhysicalSegmentLayout-ownedAttribute-14-upperValue"
                               xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#PhysicalSegmentLayout-ownedAttribute-14-upperValue"
                               xmi:type="uml:LiteralUnlimitedNatural">
                     <value>*</value>
                  </upperValue>
                  <association xmi:idref="ddsc.PhysicalSegmentLayout_has_ValueMappingPosition"/>
               </ownedAttribute>
            </packagedElement>
            <packagedElement xmi:id="ddsc.ValueMapping"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#ValueMapping"
                              xmi:type="uml:Class">
               <ownedComment xmi:id="ddsc.ValueMapping-ownedComment"
                              xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#ValueMapping-ownedComment"
                              xmi:type="uml:Comment">
                  <body>Definition 
==========
Physical characteristics for the value of an instance variable stored in a data point as part of a physical segment layout.

Examples 
========
A variable "age" might be represented in a file as a string with a maximum length of 5 characters and a number pattern of ##0.0  

Explanatory notes 
=================
An instance variable has details of value domain and data type, but will not have the final details of how a value is physically represented in a data file. A variable for height, for example, may be represented as a real number, but may be represented as a string in multiple ways. The decimal separator might be, for example a period or a comma. The string representing the value of a payment might be preceded by a currency symbol. The same numeric value might be written as "1,234,567" or "1.234567". A missing value might be written as ".", "NA", ".R" or as "R". The value mapping describes how the value of an instance variable is physically expressed. The properties of the value mapping as intended to be compatible with the W3C Metadata Vocabulary for Tabular Data (https://www.w3.org/TR/tabular-metadata/) as well as common programming languages and statistical packages. The 'format' property, for example, can draw from an external controlled vocabulary such as the set of formats for Stata, SPSS, or SAS.</body>
                  <annotatedElement xmi:idref="ddsc.ValueMapping"/>
               </ownedComment>
               <name>ValueMapping</name>
               <ownedAttribute xmi:id="ddsc.ValueMapping-decimalPositions"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#ValueMapping-decimalPositions"
                                xmi:type="uml:Property">
                  <ownedComment xmi:id="ddsc.ValueMapping-decimalPositions-ownedComment"
                                 xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#ValueMapping-decimalPositions-ownedComment"
                                 xmi:type="uml:Comment">
                     <body>The number of decimal positions expressed as an integer. Used when the decimal position is implied (no decimal separator is present) See DDI 3.2 ManagedNumericRepresentation_decimalPositions</body>
                     <annotatedElement xmi:idref="ddsc.ValueMapping-decimalPositions"/>
                  </ownedComment>
                  <name>decimalPositions</name>
                  <type xmi:type="uml:PrimitiveType"
                         href="http://www.eclipse.org/uml2/5.0.0/UML/PrimitiveTypes.xmi#Integer"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.ValueMapping-defaultDecimalSeparator"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#ValueMapping-defaultDecimalSeparator"
                                xmi:type="uml:Property">
                  <ownedComment xmi:id="ddsc.ValueMapping-defaultDecimalSeparator-ownedComment"
                                 xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#ValueMapping-defaultDecimalSeparator-ownedComment"
                                 xmi:type="uml:Comment">
                     <body>Default value is "." (period). The character separating the integer part from the fractional part of a decimal or real number. From the W3C Recommendation "Metadata Vocabulary for Tabular Data" (https://www.w3.org/TR/tabular-metadata/) 6.4.2: "decimalChar: A string whose value is used to represent a decimal point within the number. If the supplied value is not a string, implementations MUST issue a warning and proceed as if the property had not been specified."</body>
                     <annotatedElement xmi:idref="ddsc.ValueMapping-defaultDecimalSeparator"/>
                  </ownedComment>
                  <name>defaultDecimalSeparator</name>
                  <type xmi:type="uml:PrimitiveType"
                         href="http://www.eclipse.org/uml2/5.0.0/UML/PrimitiveTypes.xmi#String"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.ValueMapping-length"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#ValueMapping-length"
                                xmi:type="uml:Property">
                  <ownedComment xmi:id="ddsc.ValueMapping-length-ownedComment"
                                 xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#ValueMapping-length-ownedComment"
                                 xmi:type="uml:Comment">
                     <body>The length in characters of the physical representation of the value. From the W3C Recommendation "Metadata Vocabulary for Tabular Data" (https://www.w3.org/TR/tabular-metadata/)  5.11.2 "length: A numeric atomic property that contains a single integer that is the exact length of the value. The value of this property becomes the length annotation for the described datatype. See Length Constraints in [tabular-data-model] for details." Corresponds to DDI2.5 var/location/width and DDI 3.2 PhysicalLocation/Width.</body>
                     <annotatedElement xmi:idref="ddsc.ValueMapping-length"/>
                  </ownedComment>
                  <name>length</name>
                  <type xmi:type="uml:PrimitiveType"
                         href="http://www.eclipse.org/uml2/5.0.0/UML/PrimitiveTypes.xmi#Integer"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.ValueMapping-maximumLength"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#ValueMapping-maximumLength"
                                xmi:type="uml:Property">
                  <ownedComment xmi:id="ddsc.ValueMapping-maximumLength-ownedComment"
                                 xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#ValueMapping-maximumLength-ownedComment"
                                 xmi:type="uml:Comment">
                     <body>The largest possible value of the length of the physical representation of the value. From the W3C Recommendation "Metadata Vocabulary for Tabular Data" (https://www.w3.org/TR/tabular-metadata/) 5.11.2: "maxLength: A numeric atomic property that contains a single integer that is the maximum length of the value. The value of this property becomes the maximum length annotation for the described datatype. See Length Constraints in [tabular-data-model] for details."</body>
                     <annotatedElement xmi:idref="ddsc.ValueMapping-maximumLength"/>
                  </ownedComment>
                  <name>maximumLength</name>
                  <type xmi:type="uml:PrimitiveType"
                         href="http://www.eclipse.org/uml2/5.0.0/UML/PrimitiveTypes.xmi#Integer"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.ValueMapping-minimumLength"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#ValueMapping-minimumLength"
                                xmi:type="uml:Property">
                  <ownedComment xmi:id="ddsc.ValueMapping-minimumLength-ownedComment"
                                 xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#ValueMapping-minimumLength-ownedComment"
                                 xmi:type="uml:Comment">
                     <body>The smallest possible value for the length of the physical representation of the value. From the W3C Recommendation "Metadata Vocabulary for Tabular Data" (https://www.w3.org/TR/tabular-metadata/)  5.11.2: "minLength: An atomic property that contains a single integer that is the minimum length of the value. The value of this property becomes the minimum length annotation for the described datatype. See Length Constraints in [tabular-data-model] for details."</body>
                     <annotatedElement xmi:idref="ddsc.ValueMapping-minimumLength"/>
                  </ownedComment>
                  <name>minimumLength</name>
                  <type xmi:type="uml:PrimitiveType"
                         href="http://www.eclipse.org/uml2/5.0.0/UML/PrimitiveTypes.xmi#Integer"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.ValueMapping-ownedAttribute-6"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#ValueMapping-ownedAttribute-6"
                                xmi:type="uml:Property">
                  <type xmi:idref="ddsc.InstanceVariable"/>
                  <upperValue xmi:id="ddsc.ValueMapping-ownedAttribute-6-upperValue"
                               xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#ValueMapping-ownedAttribute-6-upperValue"
                               xmi:type="uml:LiteralUnlimitedNatural">
                     <value>*</value>
                  </upperValue>
                  <association xmi:idref="ddsc.ValueMapping_formats_InstanceVariable"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.ValueMapping-ownedAttribute-7"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#ValueMapping-ownedAttribute-7"
                                xmi:type="uml:Property">
                  <type xmi:idref="ddsc.RepresentedVariable"/>
                  <upperValue xmi:id="ddsc.ValueMapping-ownedAttribute-7-upperValue"
                               xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#ValueMapping-ownedAttribute-7-upperValue"
                               xmi:type="uml:LiteralUnlimitedNatural">
                     <value>*</value>
                  </upperValue>
                  <association xmi:idref="ddsc.ValueMapping_formats_RepresentedVariable"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.ValueMapping-ownedAttribute-8"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#ValueMapping-ownedAttribute-8"
                                xmi:type="uml:Property">
