                  <type xmi:idref="ddsc.PrimaryKey"/>
                  <association xmi:idref="ddsc.WideDataStructure_has_PrimaryKey"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.WideDataStructure-ownedAttribute-2"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#WideDataStructure-ownedAttribute-2"
                                xmi:type="uml:Property">
                  <type xmi:idref="ddsc.IdentifierComponent"/>
                  <upperValue xmi:id="ddsc.WideDataStructure-ownedAttribute-2-upperValue"
                               xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#WideDataStructure-ownedAttribute-2-upperValue"
                               xmi:type="uml:LiteralUnlimitedNatural">
                     <value>*</value>
                  </upperValue>
                  <association xmi:idref="ddsc.WideDataStructure_has_IdentifierComponent"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.WideDataStructure-ownedAttribute-3"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#WideDataStructure-ownedAttribute-3"
                                xmi:type="uml:Property">
                  <type xmi:idref="ddsc.AttributeComponent"/>
                  <upperValue xmi:id="ddsc.WideDataStructure-ownedAttribute-3-upperValue"
                               xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#WideDataStructure-ownedAttribute-3-upperValue"
                               xmi:type="uml:LiteralUnlimitedNatural">
                     <value>*</value>
                  </upperValue>
                  <association xmi:idref="ddsc.WideDataStructure_has_AttributeComponent"/>
               </ownedAttribute>
               <ownedAttribute xmi:id="ddsc.WideDataStructure-ownedAttribute-4"
                                xmi:uuid="http://w3id.org/cdif/ddsc/1.0/ddsc/xmi/#WideDataStructure-ownedAttribute-4"
